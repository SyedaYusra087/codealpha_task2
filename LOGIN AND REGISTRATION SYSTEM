using namespace std;

// -------------------------------------------------------------------
// Simple XOR obfuscation (not real encryption, but hides plain text)
// -------------------------------------------------------------------
const char XOR_KEY = 0x5A;   // arbitrary key

string encode(const string& input) {
    string output = input;
    for (char& c : output)
        c ^= XOR_KEY;
    return output;
}

string decode(const string& input) {
    return encode(input);   // XOR is symmetric
}

// -------------------------------------------------------------------
// Check if a username already exists in the user file
// -------------------------------------------------------------------
bool usernameExists(const string& username, const string& filename = "users.txt") {
    ifstream file(filename);
    if (!file.is_open())
        return false;   // file does not exist yet -> no duplicate

    string line;
    while (getline(file, line)) {
        stringstream ss(line);
        string storedUser, storedPassEnc;
        if (ss >> storedUser >> storedPassEnc) {
            if (storedUser == username)
                return true;
        }
    }
    return false;
}

// -------------------------------------------------------------------
// Register a new user
// -------------------------------------------------------------------
bool registerUser() {
    string username, password;
    cout << "\n=== REGISTRATION ===\n";
    cout << "Enter username: ";
    cin >> username;
    cout << "Enter password: ";
    cin >> password;

    // Basic validation
    if (username.empty() || password.empty()) {
        cout << "Error: Username and password cannot be empty.\n";
        return false;
    }
    if (usernameExists(username)) {
        cout << "Error: Username already exists. Choose a different one.\n";
        return false;
    }

    // Store encoded password
    string encodedPass = encode(password);
    ofstream file("users.txt", ios::app);
    if (!file) {
        cout << "Error: Could not open user database.\n";
        return false;
    }
    file << username << " " << encodedPass << endl;
    file.close();

    cout << "Registration successful! You can now log in.\n";
    return true;
}

// -------------------------------------------------------------------
// Login an existing user
// -------------------------------------------------------------------
bool loginUser() {
    string username, password;
    cout << "\n=== LOGIN ===\n";
    cout << "Username: ";
    cin >> username;
    cout << "Password: ";
    cin >> password;

    ifstream file("users.txt");
    if (!file) {
        cout << "Error: No user database found. Please register first.\n";
        return false;
    }

    string line;
    while (getline(file, line)) {
        stringstream ss(line);
        string storedUser, storedPassEnc;
        if (ss >> storedUser >> storedPassEnc) {
            if (storedUser == username) {
                string decryptedPass = decode(storedPassEnc);
                if (decryptedPass == password) {
                    cout << "Login successful! Welcome, " << username << ".\n";
                    return true;
                }
                else {
                    cout << "Login failed: Incorrect password.\n";
                    return false;
                }
            }
        }
    }
    cout << "Login failed: Username not found.\n";
    return false;
}

// -------------------------------------------------------------------
// Main menu
// -------------------------------------------------------------------
int main() {
    int choice;
    do {
        cout << "\n=================================\n";
        cout << "   LOGIN & REGISTRATION SYSTEM\n";
        cout << "=================================\n";
        cout << "1. Register\n";
        cout << "2. Login\n";
        cout << "3. Exit\n";
        cout << "Your choice: ";
        cin >> choice;

        switch (choice) {
        case 1:
            registerUser();
            break;
        case 2:
            loginUser();
            break;
        case 3:
            cout << "Goodbye!\n";
            break;
        default:
            cout << "Invalid choice. Please try again.\n";
        }
    } while (choice != 3);

    return 0;
}
